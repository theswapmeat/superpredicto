# Copy to .env (gitignored) before deploying. doctl substitutes these into the
# function's environment at deploy time via the ${VAR} refs in project.yml.

# Your deployed app's base URL, no trailing slash.
APP_URL=https://your-app.ondigitalocean.app

# Must exactly equal the app's INTERNAL_SYNC_TOKEN env var.
SYNC_TOKEN=replace-with-your-internal-sync-token
